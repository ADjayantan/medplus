# ============================================================
#  MedPlus — Environment Variables
#  Copy this file to .env  →  cp .env.example .env
#  NEVER commit the real .env file to GitHub!
# ============================================================

# ── MongoDB Atlas Connection String ──────────────────────────
# Replace YOUR_PASSWORD with your Atlas DB user password
# The /medplus at the end sets the database name
MONGO_URI=mongodb+srv://medplus123:YOUR_PASSWORD@cluster0.no4f9qq.mongodb.net/medplus?appName=Cluster0

# ── JWT Secret ───────────────────────────────────────────────
# Use a long random string — do NOT use the example below in production
JWT_SECRET=change_this_to_a_long_random_secret_key_minimum_32_chars

# ── Server Port ──────────────────────────────────────────────
# Render sets PORT automatically — keep this as 3000 for local
PORT=3000

# ── Frontend URL (for CORS) ───────────────────────────────────
# Set this to your GitHub Pages URL after deploying
# Example: https://yourname.github.io
FRONTEND_URL=https://YOUR_GITHUB_USERNAME.github.io

# ============================================================
#  RENDER SETUP — Add ALL 4 variables above in:
#  Render Dashboard → Your Service → Environment tab
# ============================================================

