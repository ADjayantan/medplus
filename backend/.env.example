# ============================================================
#  MedPlus — Environment Variables
#  Copy this file to .env  →  cp .env.example .env
#  NEVER commit the real .env file to GitHub!
# ============================================================

# ── MongoDB Connection String ─────────────────────────────────
MONGO_URI=mongodb+srv://<username>:<password>@<your-cluster>.mongodb.net/medplus

# ── JWT Secret ───────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_key_minimum_32_chars

# ── Server Port ──────────────────────────────────────────────
PORT=3000

# ── Frontend URL (for CORS) ───────────────────────────────────
FRONTEND_URL=https://YOUR_GITHUB_USERNAME.github.io

# ── Cloudinary (product image uploads) ───────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── OpenRouter AI (chatbot) ───────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── FDA Drug Event API ────────────────────────────────────────
FDA_API_KEY=your_fda_api_key_here

# ── Node environment ──────────────────────────────────────────
NODE_ENV=production
